# {{ ansible_managed }}
{%  set settings = tpl_settings['tls-baseline'] | ansible.builtin.default({}) %}

### Basic TLS config
#
# Use modern ciphers, Forward Secrecy, Diffie Hellman Ephemeral Parameters.
# Do not forget to define a certificate in your site config after including
# this snippet:
#   ssl_certificate <path to cert>;
#   ssl_certificate_key <path to key>;
#
# ATTENTION: This will exclude real(!) legacy clients. You need to use another
#            config if you must serve older MSIEs, Android 4 and comparable.
#            See "References" for more information.
#
# References:
#
# - https://ssl-config.mozilla.org/
# - https://wiki.mozilla.org/Security/Server_Side_TLS#Intermediate_compatibility_.28recommended.29
ssl_protocols TLSv1.2 TLSv1.3; # TLSv1.3 requires nginx >= 1.13.0

# Let the server enforce its cipher preference order. For TLS 1.3 the cipher
# preference is client-side by design (the server cipher list is ignored), so
# this directive only has effect on TLS 1.2 connections.
ssl_prefer_server_ciphers on;

# DH parameters for Diffie-Hellman key exchange (TLS 1.2 DHE suites). This role
# ships the pre-defined ffdhe3072 group from RFC 7919 and deploys it
# automatically. Using standardized, audited parameters is more secure than
# randomly generating custom ones (which may have weak properties) and avoids
# the slow `openssl dhparam` generation step.
#
# References:
#
# - https://www.rfc-editor.org/rfc/rfc7919
# - https://wiki.mozilla.org/Security/Server_Side_TLS?oldid=1212843#Pre-defined_DHE_groups
ssl_dhparam {{ settings['dhparam_path'] | ansible.builtin.default('/etc/ssl/certs/dhparam_ffdhe3072.pem') }};

# Cipher suite selection, following Mozilla "Intermediate" profile. Includes
# both AES-GCM and ChaCha20-Poly1305 ciphers: ChaCha20 is significantly faster
# on hardware without AES-NI acceleration (most ARM/mobile devices) while
# AES-GCM benefits from hardware acceleration on modern x86 CPUs.
#
# References:
#
# - https://ssl-config.mozilla.org/
# - https://wiki.mozilla.org/Security/Server_Side_TLS#Intermediate_compatibility_.28recommended.29
ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384:DHE-RSA-CHACHA20-POLY1305;

# Elliptic curves for ECDHE key exchange. X25519 (Curve25519) is the fastest
# and preferred choice; secp256r1 (P-256) and secp384r1 (P-384) ensure broad
# compatibility with clients that do not yet support X25519.
#
# References:
#
# - https://ssl-config.mozilla.org/
# - https://safecurves.cr.yp.to/
ssl_ecdh_curve X25519:secp256r1:secp384r1; # X25519 requires nginx >= 1.11.0



### TLS Session Resumption
#
# Resuming an encrypted session through a session ID means that the server keeps
# track of recent negotiated sessions using unique session IDs. This avoids a
# full TLS handshake on reconnection, reducing latency and CPU usage.
#
# Session tickets are disabled because they undermine Forward Secrecy: the
# ticket encryption key is a long-lived secret, and its compromise allows
# decryption of all sessions encrypted with it.
#
# References:
#
# - https://ssl-config.mozilla.org/
# - https://blog.cloudflare.com/tls-session-resumption-full-speed-and-secure/
ssl_session_timeout 1d;
ssl_session_cache shared:SSL:10m; # about 40000 sessions (says https://ssl-config.mozilla.org/)
ssl_session_tickets off; # requires nginx >= 1.5.9



### OCSP Stapling
#
# Allows the server to send a cached OCSP response during the TLS handshake,
# so the client does not need to contact the CA's OCSP responder itself. This
# provides privacy advantages (clients do not leak which sites they visit to
# the CA) and improves TLS handshake latency.
#
# A local DNS resolver is required so NGINX can look up the CA's OCSP responder
# hostname and react to changing IPs without restart.
#
# References:
#
# - https://ssl-config.mozilla.org/
# - https://wiki.mozilla.org/Security/Server_Side_TLS#OCSP_Stapling
# - https://raymii.org/s/tutorials/OCSP_Stapling_on_nginx.html
ssl_stapling on; # requires nginx >= 1.3.7
ssl_stapling_verify on; # requires nginx >= 1.3.7
{%  set resolvers = settings['resolvers'] | ansible.builtin.default(['8.8.8.8', '1.1.1.1']) %}
{%  set resolver_timeout = settings['resolver_timeout'] | ansible.builtin.default('5s') %}
resolver {{ resolvers | ansible.builtin.join(' ') }} valid=300s;
resolver_timeout {{ resolver_timeout }};
