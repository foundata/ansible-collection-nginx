### Basic TLS config
#
# Use modern chipers, Forward Secrecy, Diffie Hellman Ephemeral Parameters.
# Do not forget to define a certificate in your host after including this:
#   ssl_certificate <path to cert>;
#   ssl_certificate_key <path to key>:
#
# ATTENTION: This will exclude real(!) legacy clients. You need to use another
#            config if you must server older MSIEs, Android 4 and comparable.
#            See "References" for more information.
#
# References:
#
# * https://ssl-config.mozilla.org/
# * https://cipherlist.eu/ (formerly https://cipherli.st/, see https://is.gd/FtYBcr)
# * https://raymii.org/s/tutorials/Strong_SSL_Security_On_nginx.html
# * https://wiki.mozilla.org/Security/Server_Side_TLS#Modern_compatibility
# * https://wiki.mozilla.org/Security/Server_Side_TLS?oldid=1212843#Pre-defined_DHE_groups

ssl_protocols TLSv1.2 TLSv1.3; # TLSv1.3 requires nginx >= 1.13.0
ssl_prefer_server_ciphers on;
ssl_dhparam /etc/ssl/private/dhparam_ffdhe3072.pem;
ssl_ciphers EECDH+AESGCM:EDH+AESGCM;
ssl_ecdh_curve secp384r1; # requires nginx >= 1.1.0



### TLS Session Resumption
#
# Resuming an encrypted session through a session ID means that the server keeps
# track of recent negotiated sessions using unique session IDs.
#
# References:
#
# * https://ssl-config.mozilla.org/
# * https://blog.cloudflare.com/tls-session-resumption-full-speed-and-secure/

ssl_session_timeout 1d;
ssl_session_cache shared:SSL:10m; # about 40000 sessions (says https://ssl-config.mozilla.org/)
ssl_session_tickets off; # requires nginx >= 1.5.9



### OCSP Stapling
#
# This provides privacy advantages as clients do create fewer or no request
# against the CA. Using nginx's own DNS resolver is needed to react smoothly
# to changing CA OSCP IPs without restarting the service
#
# References:
#
# * https://ssl-config.mozilla.org/
# * https://raymii.org/s/tutorials/Strong_SSL_Security_On_nginx.html#OCSP_Stapling
# * https://raymii.org/s/tutorials/OCSP_Stapling_on_nginx.html
# * https://wiki.mozilla.org/Security/Server_Side_TLS#OCSP_Stapling

ssl_stapling on; # requires nginx >= 1.3.7
ssl_stapling_verify on; # requires nginx >= 1.3.7
resolver 8.8.8.8 1.1.1.1 valid=300s; # Google and Cloudflare DNS; might be replaced with an own DNS server for privacy reasons
resolver_timeout 5s;
